{
  "name": "ck3-strategy-advisor",
  "version": "0.1.0",
  "description": "A local, read-only Model Context Protocol server that reads your latest Crusader Kings III save and exposes your strategic situation to Claude as curated tools.",
  "type": "module",
  "license": "MIT",
  "author": "Thom Andretti",
  "homepage": "https://github.com/thomandretti/ck3-strategy-advisor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomandretti/ck3-strategy-advisor.git"
  },
  "bugs": {
    "url": "https://github.com/thomandretti/ck3-strategy-advisor/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "crusader-kings-iii",
    "ck3",
    "claude",
    "paradox"
  ],
  "engines": { "node": ">=20" },
  "bin": { "ck3-advisor": "dist/index.js" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "adm-zip": "^0.5.16",
    "jomini": "^0.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
